      "npc_ids": ["npc_scholar"],
      "topic": "雨巷私谈氛围",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["雨巷", "私谈", "脚步", "顾闻", "城门"],
      "content": "雨巷可出现压低的脚步声、墙根积水、远处巡夜声和顾闻急于离开的焦躁。",
      "usage_rule": "只用于氛围和紧张感，不自动触发城门搜检线索。"
    },
