      "material_type": "object_detail",
      "stage": ["investigation", "reversal"],
      "scene_ids": ["scene_engraving_room"],
      "npc_ids": ["npc_worker"],
      "topic": "木版与雕版细节",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["木版", "雕版", "刻刀", "木纹", "阿沈"],
      "content": "木版边缘可有浅浅刀痕、木纹和未扫净的碎屑，刻工说话时可能下意识摸刻刀柄。",
      "usage_rule": "只补强动作，不释放物证。"
    },
