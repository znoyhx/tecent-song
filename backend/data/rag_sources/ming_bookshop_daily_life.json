      "npc_ids": ["npc_owner", "npc_worker", "npc_jinyiwei"],
      "topic": "后院火场细节",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["后院", "火场", "灰烬", "雨水", "烟气"],
      "content": "火场可有雨水压下的烟气、湿灰、烧焦木味和被踩乱的泥水。",
      "usage_rule": "只增强现场感，不替代火起点、火油味等线索。"
