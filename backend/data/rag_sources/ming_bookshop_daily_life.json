      "npc_ids": ["npc_worker", "npc_owner"],
      "topic": "夜间赶工与听声",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["三更", "夜间", "赶工", "脚步", "门口"],
      "content": "夜间赶工时，刻版间内声响细碎，门口脚步、箱子摩擦和雨声更容易被胆小的工匠记住。",
      "usage_rule": "只辅助阿沈证词氛围，不直接证明谁搬箱。"
    },
