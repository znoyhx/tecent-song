      "npc_ids": ["npc_owner", "npc_worker", "npc_scholar", "npc_jinyiwei"],
      "topic": "禁止调阅密档捷径",
      "source_level": "A",
      "severity": "high",
      "keywords": ["密档", "调阅", "档案", "官府", "查看"],
      "content": "不得出现 NPC 带玩家直接查看官府密档、翻出完整账册原卷或用官府档案立刻证明真相的捷径。",
      "usage_rule": "禁止内容；必须回到已发现线索、证词和现场细节。"
    }
  ]
