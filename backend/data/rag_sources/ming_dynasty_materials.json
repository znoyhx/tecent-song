      "topic": "书坊封锁与临时盘问",
      "source_level": "A",
      "severity": "high",
      "keywords": ["封锁", "盘问", "锦衣卫", "前后门", "陆峥"],
      "content": "封锁书坊时可表现前后门有人看守、进出受限、低声盘问和对残页去向的压迫感。",
      "usage_rule": "只增强封锁压迫感，不改变可进入场景，不替玩家触发阶段跳转。"
    },
    {
      "source_id": "ming_institution_low_status_001",
      "dynasty_id": "ming",
      "material_type": "hard_rule",
      "stage": ["intro", "investigation", "reversal", "choice"],
      "scene_ids": ["scene_front_hall", "scene_interrogation_room"],
      "npc_ids": ["npc_owner", "npc_worker", "npc_scholar", "npc_jinyiwei"],
      "topic": "书坊学徒身份边界",
      "source_level": "A",
      "severity": "high",
      "keywords": ["书坊学徒", "身份", "命令", "官差", "锦衣卫"],
      "content": "书坊学徒身份低微，可追问、求证、出示已发现线索，但不能命令官差、锦衣卫或直接调阅官府文书。",
      "usage_rule": "硬约束；不得让 NPC 承认玩家拥有官府权限。"
    },
    {
      "source_id": "ming_document_red_seal_001",
      "dynasty_id": "ming",
      "material_type": "institution",
      "stage": ["intro", "investigation", "reversal"],
      "scene_ids": ["scene_fire_yard", "scene_front_hall"],
      "npc_ids": ["npc_owner", "npc_scholar", "npc_jinyiwei"],
      "topic": "红印纸角与文书风险",
      "source_level": "A",
      "severity": "medium",
      "keywords": ["红印", "纸角", "文书", "官府", "残页"],
      "content": "带红印的纸角可暗示文书性质更敏感，使人物更谨慎，但不等同于公开完整档案内容。",
      "usage_rule": "只作为风险感和制度压力参考，不得直接说明完整文书来源。"
    },
    {
      "source_id": "ming_document_grain_ledger_001",
      "dynasty_id": "ming",
      "material_type": "institution",
      "stage": ["reversal", "choice"],
      "scene_ids": ["scene_rain_alley", "scene_interrogation_room"],
      "npc_ids": ["npc_scholar", "npc_jinyiwei"],
      "topic": "粮册抄录边界",
      "source_level": "A",
      "severity": "high",
      "keywords": ["粮册", "抄录", "边地", "残页", "顾闻"],
      "content": "粮册抄录可作为反转阶段的制度压力来源，但 NPC 只能依据已发现残页和自身所知说局部信息。",
      "usage_rule": "不得在未到反转阶段时直接说明“烧的是粮册抄录”，不得替玩家拼出完整证据链。"
    },
    {
      "source_id": "ming_document_manuscript_list_001",
      "dynasty_id": "ming",
      "material_type": "occupation",
      "stage": ["intro", "investigation"],
      "scene_ids": ["scene_front_hall", "scene_engraving_room"],
      "npc_ids": ["npc_owner", "npc_worker"],
      "topic": "稿单与书坊经营",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["稿单", "账册", "书坊", "许掌柜", "前厅"],
      "content": "书坊前厅可有稿单、账册、待取书箱和欠款记录，掌柜会以生计、客单和声誉为由回避追问。",
      "usage_rule": "只增强许掌柜压力与空间细节，不得把普通稿单变成新关键线索。"
    },
    {
      "source_id": "ming_occupation_printer_001",
      "dynasty_id": "ming",
      "material_type": "occupation",
      "stage": ["investigation", "reversal"],
      "scene_ids": ["scene_engraving_room"],
      "npc_ids": ["npc_worker"],
      "topic": "刻工夜间赶工行为",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["刻工", "刻版", "赶工", "旧墨", "木屑", "阿沈"],
      "content": "刻工可在刻版间整理木版、拂木屑、擦旧墨、压纸张，夜间赶工时对门外脚步格外敏感。",
      "usage_rule": "只作为动作和场景细节，不得变成新 clue_id。"
    },
    {
      "source_id": "ming_occupation_owner_pressure_001",
      "dynasty_id": "ming",
      "material_type": "occupation",
      "stage": ["intro", "investigation", "choice"],
      "scene_ids": ["scene_front_hall", "scene_fire_yard"],
      "npc_ids": ["npc_owner"],
      "topic": "书坊掌柜生计压力",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["许掌柜", "生计", "书坊", "客人", "欠账", "声誉"],
      "content": "许掌柜可把话题引向书坊生计、客人欠账、书箱损失和铺面声誉，以此避重就轻。",
      "usage_rule": "只作为动机与口吻补强，不得让掌柜直接承认完整真相。"
    },
    {
      "source_id": "ming_occupation_scholar_001",
      "dynasty_id": "ming",
      "material_type": "occupation",
      "stage": ["investigation", "reversal", "choice"],
      "scene_ids": ["scene_front_hall", "scene_rain_alley"],
      "npc_ids": ["npc_scholar"],
      "topic": "落第士子名节与窘迫",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["顾闻", "诗稿", "名节", "落第", "焦急"],
      "content": "落第士子可表现为清瘦、焦急、护着名节，对诗稿和抄录的说法含糊而执拗。",
      "usage_rule": "只强化顾闻口吻和处境，不得提前承认所有夹带内容。"
    },
    {
      "source_id": "ming_occupation_jinyiwei_low_rank_001",
      "dynasty_id": "ming",
      "material_type": "institution",
      "stage": ["intro", "investigation", "reversal", "choice"],
      "scene_ids": ["scene_front_hall", "scene_interrogation_room"],
      "npc_ids": ["npc_jinyiwei"],
      "topic": "低级校尉执行压力",
      "source_level": "A",
      "severity": "high",
      "keywords": ["陆峥", "校尉", "命令", "封锁", "迟疑"],
      "content": "低级校尉应体现执行命令的冷硬与压力；当命令与现场证据不合时可迟疑，但不会向学徒低头。",
      "usage_rule": "只强化陆峥压迫感和矛盾感，不得让他泄露未解锁的上级链路。"
    },
    {
      "source_id": "ming_forbidden_archive_route_001",
      "dynasty_id": "ming",
