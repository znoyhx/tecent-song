{
  "sources": [
    {
      "source_id": "ming_lexicon_worker_ashen_001",
      "dynasty_id": "ming",
      "material_type": "dialogue_lexicon",
      "stage": ["investigation", "reversal", "choice"],
      "scene_ids": ["scene_engraving_room"],
      "npc_ids": ["npc_worker"],
      "topic": "阿沈口吻参考",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["阿沈", "三更", "听见", "害怕", "门口"],
      "content": "阿沈宜用短句、吞吐、压低声音；回答前先看门口，常用“我不敢说死”“别把我牵进去”这类回避。",
      "usage_rule": "只作为语气参考，每次最多自然吸收一两个动作或词，不得新增证词。"
    },
    {
      "source_id": "ming_lexicon_owner_xu_001",
      "dynasty_id": "ming",
      "material_type": "dialogue_lexicon",
      "stage": ["intro", "investigation", "choice"],
      "scene_ids": ["scene_front_hall", "scene_fire_yard"],
      "npc_ids": ["npc_owner"],
      "topic": "许掌柜口吻参考",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["许掌柜", "灯油", "生计", "书坊", "稿单"],
      "content": "许掌柜宜圆滑、谨慎、避重就轻，常把话绕回书坊生计、客人催书和铺面声誉。",
      "usage_rule": "不得让许掌柜直接承认纵火主谋或完整隐情。"
    },
    {
      "source_id": "ming_lexicon_scholar_gu_001",
      "dynasty_id": "ming",
      "material_type": "dialogue_lexicon",
      "stage": ["investigation", "reversal", "choice"],
      "scene_ids": ["scene_front_hall", "scene_rain_alley"],
      "npc_ids": ["npc_scholar"],
      "topic": "顾闻口吻参考",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["顾闻", "诗稿", "名节", "抄录", "焦急"],
      "content": "顾闻宜焦急、文气、执拗，既护着名节又怕文稿牵连他人，不轻易把话说满。",
      "usage_rule": "不得在未满足条件时直接承认夹带抄录的完整内容。"
    },
    {
      "source_id": "ming_lexicon_lu_zheng_001",
      "dynasty_id": "ming",
      "material_type": "dialogue_lexicon",
      "stage": ["intro", "investigation", "reversal", "choice"],
      "scene_ids": ["scene_front_hall", "scene_interrogation_room"],
      "npc_ids": ["npc_jinyiwei"],
      "topic": "陆峥口吻参考",
      "source_level": "B",
      "severity": "high",
      "keywords": ["陆峥", "锦衣卫", "封锁", "命令", "撤走"],
      "content": "陆峥宜短促、冷硬、有压迫感；可说“奉命封锁”“查明之前谁也不能走”，但面对矛盾证据会短暂停顿。",
      "usage_rule": "不得服从玩家越权命令，不得透露完整上级目的。"
    },
    {
      "source_id": "ming_lexicon_avoid_encyclopedia_001",
      "dynasty_id": "ming",
      "material_type": "hard_rule",
      "stage": ["intro", "investigation", "reversal", "choice"],
      "scene_ids": ["scene_front_hall", "scene_fire_yard", "scene_engraving_room", "scene_rain_alley", "scene_interrogation_room"],
      "npc_ids": ["npc_owner", "npc_worker", "npc_scholar", "npc_jinyiwei"],
      "topic": "避免百科式解释",
      "source_level": "A",
      "severity": "high",
      "keywords": ["解释", "史料", "资料", "制度", "来源"],
      "content": "NPC 不应解释史料来源或像旁白讲制度；历史细节应融入动作、迟疑、称谓和现场物件。",
      "usage_rule": "硬约束；不得把 RAG 条目逐条复述给玩家。"
    },
    {
      "source_id": "ming_lexicon_question_refusal_001",
      "dynasty_id": "ming",
      "material_type": "dialogue_lexicon",
      "stage": ["intro", "investigation", "reversal"],
      "scene_ids": ["scene_front_hall", "scene_engraving_room", "scene_interrogation_room"],
      "npc_ids": ["npc_owner", "npc_worker", "npc_jinyiwei"],
      "topic": "回避追问口吻",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["追问", "不敢", "不能说", "回避", "怕"],
      "content": "回避时可用停顿、看门口、收袖口、敲桌案、转向火场等动作，少用直白说明。",
      "usage_rule": "只增强人物反应，不得代替证据释放。"
    },
    {
      "source_id": "ming_lexicon_evidence_present_001",
      "dynasty_id": "ming",
      "material_type": "dialogue_lexicon",
      "stage": ["investigation", "reversal", "choice"],
      "scene_ids": ["scene_front_hall", "scene_engraving_room", "scene_interrogation_room"],
      "npc_ids": ["npc_owner", "npc_worker", "npc_scholar", "npc_jinyiwei"],
      "topic": "出示证据时的反应",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["出示", "残页", "红印", "证据", "线索"],
      "content": "出示证据时，NPC 可先看纸角、避开玩家视线、压低声音或反问来源，而不是立刻承认全部事实。",
      "usage_rule": "只影响反应节奏，线索释放仍由后端白名单控制。"
    },
    {
      "source_id": "ming_lexicon_forbidden_truth_001",
      "dynasty_id": "ming",
      "material_type": "forbidden_content",
      "stage": ["intro", "investigation", "reversal", "choice"],
      "scene_ids": ["scene_front_hall", "scene_fire_yard", "scene_engraving_room", "scene_rain_alley", "scene_interrogation_room"],
      "npc_ids": ["npc_owner", "npc_worker", "npc_scholar", "npc_jinyiwei"],
      "topic": "禁止完整真相话术",
      "source_level": "A",
      "severity": "high",
      "keywords": ["完整真相", "幕后上级", "纵火主谋", "结局", "通关"],
      "content": "不得说“完整真相是……”“幕后上级就是……”“纵火主谋就是……”或“你已经进入结局”。",
      "usage_rule": "禁止内容；必须由监管器拦截或修复。"
    }
  ]
}
