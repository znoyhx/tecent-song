      "stage": ["investigation", "reversal", "choice"],
      "scene_ids": ["scene_engraving_room"],
      "npc_ids": ["npc_worker"],
      "topic": "刻工胆怯人设",
      "source_level": "B",
      "severity": "medium",
      "keywords": ["阿沈", "害怕", "作证", "袖口", "旧墨", "回避"],
      "content": "阿沈说话应短促、压低声音，先观察门口；他关心自己是否会被推出去顶罪，通常只给局部信息。",
      "usage_rule": "只作为口吻参考，不得新增证据，不得让阿沈越过信任和阶段直接作证。"
    },
    {
